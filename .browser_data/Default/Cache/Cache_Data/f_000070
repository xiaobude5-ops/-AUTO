  --monospace: Inter, Avenir, Helvetica, Arial, sans-serif;
  --yellow: #e2aa53;
}

.notfound {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #1a1a1a;
  font-family: var(--monospace)
}
.layout {
  width: 90%;
  margin: 0 auto;
  display: flex;
  height: 100%;
  align-items: center;
  justify-content: space-around;
  position: relative;
  z-index: 2;
}
.background {
  position: absolute;
  top: 0; 
  left: 0; 
  width: 100%;
  height: 100%;
  z-index: 1;
}
.background img {
  object-fit: cover;
}
.code {
  font-size: 256px;
  padding: 0;
  margin: 0;
  color: #fff;
}
.config-option {
  font-size: 13px;
  font-family: var(--monospace);
  color: var(--yellow);
}
.panel {
  min-width: 600px;
  height: 400px;
  display: flex;
  flex-direction: column;
  background-color: rgb(17, 19, 23);
  border-radius: 12px;
  padding: 40px 40px 12px 40px;
  text-align: left;
  box-shadow: 4px 12px 40px 6px rgb(0 0 0 / 9%), inset 0 0 1px 1px hsl(0deg 0% 100% / 5%);
}
.title {
  padding: 0px;
  margin: 0px;
  font-weight: 700;
  color: #fff;
}
.desc {
  padding: 0;
  margin: 0;
  color: rgb(231, 231, 231);
  font-weight: 600;
}
.routes {
  list-style: none;
  text-align: left;
  padding: 0px;
  margin-top: 24px;
  overflow: auto;
}
a {
  cursor: pointer;
  font-weight: 500;
  color: #646cff;
  text-decoration: inherit;
}
a:hover {
  color: #535bf2;
}
